#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/tmp/LunarCalendarBar/node_modules/.pnpm/xcodegen@2.2.0/node_modules/xcodegen/node_modules:/tmp/LunarCalendarBar/node_modules/.pnpm/xcodegen@2.2.0/node_modules:/tmp/LunarCalendarBar/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/tmp/LunarCalendarBar/node_modules/.pnpm/xcodegen@2.2.0/node_modules/xcodegen/node_modules:/tmp/LunarCalendarBar/node_modules/.pnpm/xcodegen@2.2.0/node_modules:/tmp/LunarCalendarBar/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
"$basedir/../.pnpm/xcodegen@2.2.0/node_modules/xcodegen/bin/xcodegen"   "$@"
exit $?
